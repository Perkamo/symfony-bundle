{
  "name": "perkamo/symfony-bundle",
  "description": "Symfony bundle for Perkamo backend and browser SDK integrations.",
  "type": "symfony-bundle",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Perkamo\\SymfonyBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Perkamo\\SymfonyBundle\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2",
    "ext-hash": "*",
    "ext-json": "*",
    "perkamo/sdk": "^0.6",
    "symfony/config": "^6.4 || ^7.4 || ^8.0",
    "symfony/dependency-injection": "^6.4 || ^7.4 || ^8.0",
    "symfony/http-foundation": "^6.4 || ^7.4 || ^8.0",
    "symfony/http-kernel": "^6.4 || ^7.4 || ^8.0",
    "symfony/routing": "^6.4 || ^7.4 || ^8.0",
    "symfony/security-core": "^6.4 || ^7.4 || ^8.0",
    "twig/twig": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "symfony/yaml": "^6.4 || ^7.4 || ^8.0"
  },
  "scripts": {
    "test": "phpunit",
    "lint": "find src tests config -name '*.php' -print0 | xargs -0 -n1 php -l"
  }
}
